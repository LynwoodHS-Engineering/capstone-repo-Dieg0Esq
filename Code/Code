// === YOUR EXACT L298N PINS ===
const int ENA = 9;  // Left motor speed
const int IN1 = 8;  // Left motor direction 1
const int IN2 = 7;  // Left motor direction 2
const int IN3 = 5;  // Right motor direction 1
const int IN4 = 4;  // Right motor direction 2
const int ENB = 3;  // Right motor speed

void setup() {
  Serial.begin(115200);
  
  // Set all pins as outputs
  pinMode(ENA, OUTPUT);
  pinMode(ENB, OUTPUT);
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);

  stopTank();
  Serial.println("TANK READY - Type F, B, L, R, S + ENTER");
}

// === TANK MOVEMENTS ===
void tankForward() {
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, HIGH);
  digitalWrite(IN4, LOW);
  analogWrite(ENA, 200);  // Speed 200/255
  analogWrite(ENB, 200);
  Serial.println("FORWARD");
}

void tankBackward() {
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, HIGH);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, HIGH);
  analogWrite(ENA, 200);
  analogWrite(ENB, 200);
  Serial.println("BACKWARD");
}

void tankLeft() {
  // Left track back, right forward = turn left
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, HIGH);
  digitalWrite(IN3, HIGH);
  digitalWrite(IN4, LOW);
  analogWrite(ENA, 150);
  analogWrite(ENB, 150);
  Serial.println("LEFT");
}

void tankRight() {
  // Left forward, right back = turn right
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, HIGH);
  analogWrite(ENA, 150);
  analogWrite(ENB, 150);
  Serial.println("RIGHT");
}

void stopTank() {
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);
  analogWrite(ENA, 0);
  analogWrite(ENB, 0);
  Serial.println("STOP");
}

// === SERIAL COMMAND PARSER ===
void loop() {
  if (Serial.available() > 0) {
    char cmd = Serial.read();  // Read single character
    
    switch (cmd) {
      case 'F': case 'f': tankForward(); break;
      case 'B': case 'b': tankBackward(); break;
      case 'L': case 'l': tankLeft(); break;
      case 'R': case 'r': tankRight(); break;
      case 'S': case 's': stopTank(); break;
      default: Serial.println("Unknown: " + String(cmd)); break;
    }
  }
}
